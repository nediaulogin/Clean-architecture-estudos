generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model Product {
  id        String          @id
  name      String
  price     Float
  stock     Int
  movements StockMovement[]

  @@map("products")
}

model StockMovement {
  id        String       @id
  productId String
  type      MovementType
  quantity  Int
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_movements")
}
